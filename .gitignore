# secrets & virtualenv
secrets/
.venv/

# python caches & logs
__pycache__/
*.log

# data — raw + processed are large / regenerable and stay out of git. Exception: the small,
# FRED-flaky derived macro panels are tracked so features.py runs without re-fetching them.
data/raw/*
